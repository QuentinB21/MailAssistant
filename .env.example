# PostgreSQL
POSTGRES_DB=mailassistant
POSTGRES_USER=mailassistant
POSTGRES_PASSWORD=local-development-only
POSTGRES_PORT=5432
ConnectionStrings__Database=Host=localhost;Port=5432;Database=mailassistant;Username=mailassistant;Password=local-development-only

# RabbitMQ
RABBITMQ_DEFAULT_USER=mailassistant
RABBITMQ_DEFAULT_PASS=local-development-only
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=local-development-only
KEYCLOAK_HTTP_PORT=8080
